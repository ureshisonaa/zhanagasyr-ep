# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zhanagasyr?schema=public"

# JWT
JWT_ACCESS_SECRET=changeme-access-secret
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (подключается начиная с Фазы 5)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=60000

# Google Drive (используется с Этапа 4.2). Сервисный аккаунт с доступом
# к Drive API. GOOGLE_DRIVE_ROOT_FOLDER_ID опционален — если задан, папка
# "Students" создаётся внутри него, а не в корне всего аккаунта.
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Qdrant (подключается начиная с Фазы 5)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting (Throttler)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Error tracking (Этап 12.1) — опционален. Если не задан, error tracking
# отключён (ошибки только логируются локально), приложение работает как обычно.
SENTRY_DSN=

# Bootstrap SuperAdmin — используется ТОЛЬКО скриптом prisma/seed.ts,
# так как самостоятельная регистрация на платформе отключена (Этап 1.1).
# Сменить пароль сразу после первого входа.
BOOTSTRAP_ADMIN_EMAIL=admin@zhanagasyr.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeImmediately123!
BOOTSTRAP_ADMIN_FIRST_NAME=Super
BOOTSTRAP_ADMIN_LAST_NAME=Admin
