# ШАБЛОН окружения staging (Этап 14.1) — коммитится в репозиторий пустым,
# реальные значения задаются через переменные окружения хостинга
# (Railway Environment Variables), а НЕ редактированием этого файла.
# Ни одно значение ниже не должно совпадать с production — staging
# использует отдельную БД, отдельные JWT-секреты, отдельный сервисный
# аккаунт Google Drive (см. чек-лист секретов в README, раздел "Деплой").

# Application
NODE_ENV=staging
PORT=4000
API_PREFIX=api/v1

# Database — ОТДЕЛЬНАЯ staging-база, не production (Supabase/Railway Postgres)
DATABASE_URL=

# JWT — сгенерировать собственные секреты для staging, НЕ переиспользовать production.
# Например: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI — можно переиспользовать тот же ключ, что и в production (общий биллинг),
# но с отдельным usage-лимитом/algorithm rate-limit на стороне OpenAI, если возможно
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=60000

# Google Drive — РЕКОМЕНДУЕТСЯ отдельный сервисный аккаунт/корневая папка от
# production, чтобы staging-тесты не засоряли реальные файлы студентов
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Qdrant — отдельный инстанс/коллекция от production
QDRANT_URL=
QDRANT_API_KEY=

# CORS — домен staging-фронтенда (например preview-деплой Vercel)
CORS_ORIGIN=

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Error tracking — ОТДЕЛЬНЫЙ Sentry-проект или тот же с environment=staging,
# чтобы staging-ошибки не смешивались с production в одной ленте
SENTRY_DSN=

# Bootstrap SuperAdmin — staging-аккаунт, пароль сменить сразу после первого входа
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FIRST_NAME=Super
BOOTSTRAP_ADMIN_LAST_NAME=Admin
