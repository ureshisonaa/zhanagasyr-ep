# ШАБЛОН окружения production (Этап 14.1) — коммитится в репозиторий пустым,
# реальные значения задаются через переменные окружения хостинга
# (Railway Environment Variables), а НЕ редактированием этого файла.
# См. чек-лист секретов в README, раздел "Деплой" — перед первым запуском
# в production убедиться, что каждое значение ниже задано, уникально для
# production (не переиспользовано из staging/dev) и нигде не закоммичено.

# Application
NODE_ENV=production
PORT=4000
API_PREFIX=api/v1

# Database — production БД (Supabase/Railway Postgres), регулярные бэкапы обязательны
DATABASE_URL=

# JWT — уникальные секреты, сгенерированные для production.
# Например: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI — production API-ключ, желательно с отдельным usage-лимитом от staging
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=60000

# Google Drive — production-сервисный аккаунт, доступ только к своей корневой папке
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Qdrant — production-инстанс/коллекция
QDRANT_URL=
QDRANT_API_KEY=

# CORS — домен production-фронтенда (например app.zhanagasyr.kz на Vercel)
CORS_ORIGIN=

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Error tracking — production Sentry-проект
SENTRY_DSN=

# Bootstrap SuperAdmin — сменить пароль немедленно после первого входа,
# затем рассмотреть возможность отозвать/деактивировать этот аккаунт,
# если созданы именные SuperAdmin-аккаунты через Admin Panel (Этап 11.1)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FIRST_NAME=Super
BOOTSTRAP_ADMIN_LAST_NAME=Admin
